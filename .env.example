# HuggingFace token used by both embedding and generation clients.
# Keep this empty in template files and set it in your local .env.
HF_API_TOKEN=

# Internal RAG model settings (free/open models)
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_GENERATION_MODEL=facebook/bart-large-cnn

# Legacy fallback summarizer model
HF_MODEL=facebook/bart-large-cnn

# Enable debug logging
DEBUG=false
